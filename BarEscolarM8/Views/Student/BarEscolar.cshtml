@model IEnumerable<BarEscolarM8.Models.ProductDto>
@{
    var categorias = ViewBag.Categorias as IEnumerable<dynamic>;
    int? selectedCategoryId = (int?)ViewBag.SelectedCategoryId;
    string minPrice = ViewBag.MinPrice as string;
    string maxPrice = ViewBag.MaxPrice as string;
}

@if (TempData["ErroCompra"] is string erro)
{
    <div class="alert alert-danger text-center mb-3">
        <p class="mb-1">@erro</p>
    </div>
}
<!-- PRODUCTS TABLE -->
<div class="admin-table-wrapper mb-5">
    <h1 class="page-title">Loja de Produtos</h1>
    <div class="top-buttons">
        <center>
            <a asp-action="ProdutosComprados" class="btn btn-primary">Produtos Marcados</a>
        </center>
    </div>

<form method="get" asp-action="BarEscolar" class="mb-4">
    <div class="row g-3">

        <div class="col-md-3">
            <label class="form-label">Categoria</label>
                <select name="categoryId" class="form-select">
                    <option value="">Todas</option>
                    @if (categorias != null)
                    {
                        foreach (var c in categorias)
                        {
                            <option value="@c.CategoryId"
                                    selected="@(selectedCategoryId == (int?)c.CategoryId ? "selected" : null)">
                                @c.CategoryName
                            </option>
                        }
                    }
                </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Preço Mínimo</label>
                <input type="number"
                       name="minPrice"
                       step="0.01"
                       class="form-control"
                       value="@minPrice" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Preço Máximo</label>
                <input type="number"
                       name="maxPrice"
                       step="0.01"
                       class="form-control"
                       value="@maxPrice" />
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Filtrar</button>
        </div>

    </div>
</form>


    <table class="admin-table">
        <thead>
            <tr>
                <th>Imagem</th>
                <th>Nome</th>
                <th>Categoria</th>
                <th>Preço</th>
                <th>Stock</th>
                <th>Descrição</th>
                <td>Quantidade</td>
                <th style="width: 160px;"></th>
                <th style="width: 160px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                @if(p.Stock <= 0)
                {
                    continue; // Skip products that are out of stock
				}
                <tr>
                    <td class="text-center mb-3">
                        @if (string.IsNullOrEmpty(p.ImageUrl))
                        {
                            <span>Sem Imagem</span>
                        }
                        else
                        {
                            <img src="@p.ImageUrl" style="width:80px; height:auto;" />
                        }
                    </td>
                    <td>@p.Name</td>
                    <td>@p.CategoryName</td>
                    <td>@p.Price.ToString("F2") €</td>
                    <td>@p.Stock</td>
                    <td>@p.Description</td>
                    <td>
                        <form asp-action="ComprarProduto" asp-route-id="@p.Id" method="post" class="d-flex align-items-center gap-2">

                            <input type="number"
                                   name="qtd"
                                   class="form-control form-control-sm"
                                   value="1"
                                   min="1"
                                   max="@p.Stock"
                                   style="width: 80px;" />

                            <button type="submit" class="btn btn-success btn-sm">
                                Comprar
                            </button>
                        </form>

                    </td>
                    <td>
                        <a asp-action="Details"
                           asp-route-id="@p.Id"
                           class="btn btn-info btn-sm ms-2">
                            Detalhes
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>
