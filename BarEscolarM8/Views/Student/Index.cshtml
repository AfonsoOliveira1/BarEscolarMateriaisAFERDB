@model IEnumerable<MenuWeekDto>
@using System.Security.Claims;
@{
    ViewData["Title"] = "Aluno";
}

<h1 class="page-title">
    Bem-vindo, @User.FindFirst("FullName").Value
</h1>

<!-- Top Buttons -->
<div class="top-buttons">
    <center>
        <a asp-action="BarEscolar" class="btn btn-primary">Bar da Escola</a>
        <a asp-action="Materiais" class="btn btn-primary">Materiais da Escola</a>
    </center>
</div>

<h2>Historico de Menus</h2>

<div class="top-buttons">
    <center>
        <a asp-action="MenusMarcados" class="btn btn-primary">Menus Marcados</a>
    </center>
</div>

<h2>Menus da Semana</h2>

<!-- Vegan / Não-Vegan Tabs -->
<div class="menu-tabs">
    <a asp-action="Index"
       asp-route-option="A"
       class="tab-active">
        Não-Vegan
    </a>

    <a asp-action="Index"
       asp-route-option="B"
       class="tab-active">
        Vegan
    </a>
</div>
@if (TempData["ErroMarcar"] is string erro)
{
    <div class="alert alert-danger text-center mb-3">
        <p class="mb-1">@erro</p>
    </div>
}
<!-- Week Cards -->
@foreach (var week in Model)
{
    <div class="card mb-4 shadow-sm p-3">
        <h4>Semana começando em: @week.Weekstart</h4>

        <table class="table cafeteria-table table-striped mt-2">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Prato Principal</th>
                    <th>Sopa</th>
                    <th>Sobremesa</th>
                    <th>Notas</th>
                    <th>Tipo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var menuDay in week.MenuDays)
                {
                    <tr>
                        <td>@menuDay.Date</td>
                        <td>@menuDay.MainDish</td>
                        <td>@menuDay.Soup</td>
                        <td>@menuDay.Dessert</td>
                        <td>@menuDay.Notes</td>
                        <td>@menuDay.Option</td>
                        <td>
                            
                            @{
                                var marked = ((List<int>)ViewBag.MarkedMenuIds).Contains(menuDay.Id);
                            }

                            @if (marked)
                            {
                                <button class="btn btn-secondary btn-sm" disabled>Marcado ✓</button>
                            }
                            else
                            {
                                <form asp-action="Marcar"
                                      asp-route-menuId="@menuDay.Id"
                                      asp-route-option="@(menuDay.Option == "Não-Vegan" ? "A" : "B")"
                                      method="post"
                                      style="display:inline">
                                    <button type="submit"
                                            class="admin-btn-danger"
                                            onclick="return confirm('Marcar este Menu?')">
                                        Marcar (@menuDay.MaxSeats)
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
