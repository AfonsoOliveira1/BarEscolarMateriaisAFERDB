@model BarEscolarM8.Models.LoginModel;
@{
    ViewData["Title"] = "Login";
}

<h1 class="page-title login-page-title">Login</h1>
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger text-center mb-3">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p class="mb-1">@error.ErrorMessage</p>
        }
    </div>
}
<div class="generic-card login-card">
    <form asp-action="Login" method="post" class="login-form">
        <div class="form-group">
            <label>Email or Username</label>
            <input asp-for="EmailorUsername" class="form-input" />
            <span asp-validation-for="EmailorUsername" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input asp-for="Passwordhash" type="password" class="form-input" />
            <span asp-validation-for="Passwordhash" class="validation-error"></span>
        </div>

        <button type="submit" class="btn main-btn">Entrar</button>

        <a asp-action="Register" class="btn secondary-btn login-register-btn">
            Registrar
        </a>
    </form>
</div>