@model BarEscolarM8.Models.ProductCreateDto

@{
    ViewData["Title"] = "Editar Produto";
}

<h2 class="text-center mb-4">Editar Produto</h2>

<div class="admin-dashboard-wrapper">

    <div class="admin-card" style="max-width: 700px; margin: 0 auto;">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger text-center mb-3">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-1">@error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-action="EditProduct" method="post">

            <input type="hidden" name="id" value="@ViewContext.RouteData.Values["id"]" />

            <div class="form-group">
                <label asp-for="Name" class="form-label">Nome</label>
                <input asp-for="Name" class="form-input" />
                <span asp-validation-for="Name" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Descrição</label>
                <textarea asp-for="Description" class="form-input"></textarea>
                <span asp-validation-for="Description" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="CategoryId" class="form-label">Categoria</label>
                <select asp-for="CategoryId" class="form-input">
                    @foreach (CategoryDto cat in ViewBag.Categories)
                {
                    if(cat.Id == Model.CategoryId)
                    {
                        <option value="@Model.CategoryId" selected>@cat.Name</option>
                    }
                    else
                    {
                        <option value="@cat.Id" >@cat.Name</option>
                    }
                }
                </select>
                <span asp-validation-for="CategoryId" class="validation-error"></span>
            </div>

            <div class="row">
                <div class="col-md-4 form-group">
                    <label asp-for="Price" class="form-label">Preço (€)</label>
                    <input asp-for="Price" type="number" step="0.01" class="form-input input-small" />
                    <span asp-validation-for="Price" class="validation-error"></span>
                </div>

                <div class="col-md-4 form-group">
                    <label asp-for="Salt" class="form-label">Sal (g)</label>
                    <input asp-for="Salt" type="number" step="0.01" class="form-input input-small" />
                    <span asp-validation-for="Salt" class="validation-error"></span>
                </div>

                <div class="col-md-4 form-group">
                    <label asp-for="Stock" class="form-label">Stock</label>
                    <input asp-for="Stock" type="number" class="form-input input-small" />
                    <span asp-validation-for="Stock" class="validation-error"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-3 form-group">
                    <label asp-for="Kcal" class="form-label">Kcal</label>
                    <input asp-for="Kcal" type="number" class="form-input" />
                </div>

                <div class="col-md-3 form-group">
                    <label asp-for="Protein" class="form-label">Proteína (g)</label>
                    <input asp-for="Protein" type="number" class="form-input" />
                </div>

                <div class="col-md-3 form-group">
                    <label asp-for="Fat" class="form-label">Gordura (g)</label>
                    <input asp-for="Fat" type="number" class="form-input" />
                </div>

                <div class="col-md-3 form-group">
                    <label asp-for="Carbs" class="form-label">Carboidratos (g)</label>
                    <input asp-for="Carbs" type="number" class="form-input" />
                </div>
            </div>

            <div class="form-group">
                <div class="col-md-3 form-group">
                    <label asp-for="Allergens" class="form-label">Alergénios</label>
                    <input asp-for="Allergens" class="form-input" />
                    <span asp-validation-for="Allergens" class="validation-error"></span>
                </div>
            </div>

            <label class="custom-checkbox mb-3">
                <input asp-for="IsActive" type="checkbox" />
                Ativo
            </label>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary flex-fill">Guardar Alterações</button>
                <a asp-action="Index" class="btn btn-secondary flex-fill">Cancel</a>
            </div>
        </form>
    </div>
</div>
