@model BarEscolarM8.Models.ProdxCat

<div class="admin-dashboard-wrapper">

    <h2 class="mb-4">Gestão de Produtos e Categorias</h2>

    <div class="dashboard-actions mb-4">
        <a asp-action="CreateProduct" class="admin-btn">Criar Produto</a>
        <a asp-action="CreateCategory" class="admin-btn">Criar Categoria</a>
    </div>

    <!-- PRODUCTS TABLE -->
    <div class="admin-table-wrapper mb-5">
        <h3 class="text-center mb-3">Produtos</h3>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Imagem</th>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th>Preço</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th style="width: 160px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Products)
                {
                    <tr>
                        <td class="text-center mb-3">
                            @if (string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <span>Sem Imagem</span>
                            }
                            else
                            {
                                <img src="@p.ImageUrl" style="width:80px; height:auto;" />
                            }
                        </td>
                        <td>@p.Name</td>
                        <td>@p.CategoryName</td>
                        <td>@p.Price.ToString("F2") €</td>
                        <td>@p.Stock</td>
                        <td>
                            <span class="@(p.IsActive == true ? "status-marked" : "status-cancelled")">
                                @(p.IsActive == true ? "Ativo" : "Inativo")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details"
                               asp-route-id="@p.Id"
                               class="btn btn-info btn-sm ms-2">
                                Detalhes
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    <!-- CATEGORIES TABLE -->
    <div class="admin-table-wrapper">
        <h3 class="text-center mb-3">Categorias</h3>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Imagem</th>
                    <th>Nome</th>
                    <th>Descrição</th>
                    <th style="width: 160px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Categorys)
                {
                    <tr>
                        @if (string.IsNullOrEmpty(c.ImageUrl))
                        {
                            <td>Sem Imagem</td>
                        }
                        else
                        {
                            <td>
                                <img src="@c.ImageUrl" style="width:80px; height:auto;" />
                            </td>
                        }
                        <td>@c.Name</td>
                        <td>@c.Description</td>
                        <td>
                            <a asp-action="EditCategory"
                               asp-route-id="@c.Id"
                               class="admin-btn-warning me-2">
                                Editar
                            </a>

                            <form asp-action="DeleteCategory"
                                  asp-route-id="@c.Id"
                                  method="post"
                                  style="display:inline">
                                <button type="submit"
                                        class="admin-btn-danger"
                                        onclick="return confirm('Eliminar esta categoria?')">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- SALDO INDEX -->
    <div class="admin-table-wrapper">
        <h3 class="text-center mb-3">Pedidos de Saldo</h3>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Nome</th>
                    <th>Saldo Antigo</th>
                    <th>Saldo Pedido</th>
                    <th style="width: 160px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model.Saldos)
                {
                    <tr>
                        <td>@s.RequestDate</td>
                        <td>@s.UserName</td>
                        <td>@s.Saldo</td>
                        <td>@s.SaldoToUpdate</td>
                        <td>
                            <form asp-action="SaldoAceite" asp-route-id="@s.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-success me-2">
                                    Aceitar
                                </button>
                            </form>


                            <form asp-action="SaldoRejeitado" asp-route-id="@s.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-danger">
                                    Rejeitar
                                </button>
                            </form>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
