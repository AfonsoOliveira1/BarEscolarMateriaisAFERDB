@model BarEscolarM8.Models.MenuDayUpdateDto

<h2>Edit Menu Day</h2>

<form asp-action="EditMenuDay" method="post">
    <input type="hidden" asp-for="Menuweekid" />

    <div class="mb-3">
        <label>Edit Date Week Start</label>
        <input asp-for="Date" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Option</label>
        <select asp-for="Option" class="form-control">
            <option value="Vegan">Vegan</option>
            <option value="Non-Vegan">Non-Vegan</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Main Dish</label>
        <input asp-for="MainDish" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Soup</label>
        <input asp-for="Soup" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Dessert</label>
        <input asp-for="Dessert" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Notes</label>
        <input asp-for="Notes" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="EditMenuWeek" asp-route-id="@Model.Menuweekid" class="btn btn-secondary">Cancel</a>
</form>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-3 text-center">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p class="mb-1">@error.ErrorMessage</p>
        }
    </div>
}